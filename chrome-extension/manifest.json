{
  "manifest_version": 3,
  "name": "BrainHistory – Save to Library",
  "short_name": "BrainHistory",
  "version": "1.0.0",
  "description": "Save any webpage, article, YouTube video, or link to your BrainHistory knowledge library in one click.",

  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://brainhistory.app/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to BrainHistory",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  }
}
